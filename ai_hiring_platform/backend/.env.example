# Copy this file to .env and fill in the values. Every setting is optional —
# with no LLM key configured the platform runs fully on the deterministic engine.

# --- LLM reasoning (provider-agnostic) --------------------------------------
# Provider: openai | anthropic | google  (aliases: gemini->google, claude->anthropic)
# To use Gemini for reasoning, set:  LLM_PROVIDER=google  and  GOOGLE_API_KEY=<key>
LLM_PROVIDER=openai
# Explicit model id; leave blank for the per-provider default
# (openai=gpt-4o-mini, anthropic=claude-sonnet-5, google=gemini-2.0-flash).
# Recommended Gemini: gemini-2.0-flash (fast + cheap) or gemini-1.5-pro (max quality).
LLM_MODEL=

# API keys — set only the one matching LLM_PROVIDER. Leave all blank to run the
# deterministic reasoning engine (no network, full report still produced). A wrong
# key or an unsupported model also falls back to the deterministic engine.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# GEMINI_API_KEY is also accepted as an alias for GOOGLE_API_KEY.

# --- Persistence ------------------------------------------------------------
DATABASE_URL=sqlite:///./hiring_platform.db

# --- Retrieval tuning (optional; sensible defaults shown) --------------------
RETRIEVAL_MIN_SIMILARITY=0.30
# Hybrid retrieval: fuse dense (vector) + sparse (BM25) via Reciprocal Rank Fusion.
HYBRID_RETRIEVAL_ENABLED=true
HYBRID_WEIGHT_DENSE=0.6
HYBRID_WEIGHT_SPARSE=0.4
HYBRID_RRF_K=60
# Sentence-aware chunking.
CHUNK_TARGET_CHARS=350
CHUNK_MAX_CHARS=600
CHUNK_SENTENCE_OVERLAP=1

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
