# Copy this file to .env and fill in the values.

# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# API keys (leave empty to run the deterministic mock reasoning engine)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DATABASE_URL=sqlite:///./hiring_platform.db

# Logging
LOG_LEVEL=INFO
