# Copy to .env (or .env.local) to point the SPA at a non-default backend.
# Defaults to http://localhost:8000 when unset. Must include scheme + host
# (the client appends /api/v1 itself). Example for a deployed backend:
# VITE_API_BASE=https://hiring-api.example.com
VITE_API_BASE=http://localhost:8000
